# Doxygen configuration for the SushiEngine public API reference.
#
# Scope is the public engine surface (include/SushiEngine), the product's
# documented face. The layered design is described in docs/guides/ARCHITECTURE.md.
# Build it with `se doxygen` (or `doxygen Doxyfile`); output lands in
# docs/api-site/html.

PROJECT_NAME           = "SushiEngine"
PROJECT_BRIEF          = "Header-only ECS + physics engine — C++ API reference"
PROJECT_NUMBER         = "v0.1.0 (unreleased)"

OUTPUT_DIRECTORY       = docs/api-site
HTML_OUTPUT            = html
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# Public engine surface plus the hand-written manual landing and architecture
# guide. The reference and the manual build together, Unity-manual style.
INPUT                  = docs/api/mainpage.md \
                         docs/guides/ARCHITECTURE.md \
                         include/SushiEngine
FILE_PATTERNS          = *.hpp *.h *.md
RECURSIVE              = YES
USE_MDFILE_AS_MAINPAGE = docs/api/mainpage.md

# Keep internal plumbing out of the reference.
EXCLUDE_PATTERNS       = */detail/*
EXCLUDE_SYMBOLS        = *::detail *::detail::*

# Document the API as written; do not invent docs for undocumented symbols, and
# surface anything public that is missing one so the site stays honest.
EXTRACT_ALL            = NO
EXTRACT_STATIC         = NO
EXTRACT_PRIVATE        = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
WARN_IF_UNDOCUMENTED   = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO
WARN_LOGFILE           = docs/api-site/doxygen-warnings.log

JAVADOC_AUTOBRIEF      = YES
MARKDOWN_SUPPORT       = YES
SORT_MEMBER_DOCS       = YES
ALPHABETICAL_INDEX     = YES
SOURCE_BROWSER         = NO
QUIET                  = YES
